---
import { exportGuides } from "@/data/exportGuides";
---

<section class="no-print max-w-5xl mx-auto mt-20 sm:mb-16">
  <h2 class="text-2xl font-bold mb-8 text-white">How to export your data</h2>
  <div class="space-y-3">
    {
      exportGuides.map((guide) => (
        <details class="group bg-surface-800/30 border border-white/10 hover:border-wrap-500/50 rounded-xl overflow-hidden open:pb-4">
          <summary class="list-none cursor-pointer p-6 flex justify-between items-center hover:bg-white/[0.02] transition-colors [&::-webkit-details-marker]:hidden">
            <span class="text-lg font-medium">{guide.platform}</span>
            <span
              class="material-symbols-outlined text-text-muted group-open:rotate-45 group-hover:text-wrap-500 transition-all"
              aria-hidden="true"
            >
              add
            </span>
          </summary>
          <div class="px-6">
            {
              guide.highlight && (
                <p class="text-amber-200/90 text-sm mb-3">
                  Important: Chat history is under My Activity → Gemini Apps, not the
                  top-level Gemini checkbox.
                </p>
              )
            }
            <ol class="list-decimal list-inside text-text-muted text-sm space-y-1">
              {guide.steps.map((step) => (
                <li>{step}</li>
              ))}
            </ol>
            <a
              href={guide.url}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-block mt-4 text-wrap-500 text-sm hover:underline"
            >
              Official instructions →
            </a>
          </div>
        </details>
      ))
    }
  </div>
</section>
