---
import BaseLayout from "@/layouts/BaseLayout.astro";
import HistoryView from "@/components/react/HistoryView";
import { brand } from "@/config/brand";
---

<BaseLayout
  title={`History — ${brand.name}`}
  description="View, import, export, and delete your saved AI Wrapped monthly reports stored locally in your browser."
>
  <header class="mb-8 space-y-2">
    <h1 class="text-3xl font-bold text-white">History</h1>
    <p class="text-text-muted max-w-2xl">
      Your saved monthly wraps live on this device only. Import a report JSON backup, open a past
      month, or delete reports you no longer need.
    </p>
  </header>
  <HistoryView client:load />
</BaseLayout>
