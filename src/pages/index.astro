---
import BaseLayout from "@/layouts/BaseLayout.astro";
import PlatformGuide from "@/components/PlatformGuide.astro";
import SponsorSlot from "@/components/react/SponsorSlot";
import SupportProject from "@/components/SupportProject.astro";
import HomeUpload from "@/components/react/HomeUpload";
import { brand } from "@/config/brand";

const { samplePreview } = brand;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: "AI Wrapped",
  url: "https://theaiwrapped.com/",
  image: "https://theaiwrapped.com/og.jpg",
  description:
    "Privacy-first monthly wrap of your AI usage — estimated time spent and time saved from your export files. Runs entirely in your browser.",
  applicationCategory: "ProductivityApplication",
  operatingSystem: "Any (web browser)",
  browserRequirements: "Requires JavaScript. Requires HTML5.",
  offers: {
    "@type": "Offer",
    price: "0",
    priceCurrency: "USD",
  },
  featureList: [
    "Parses ChatGPT, Claude, Grok, and Gemini exports",
    "Supports Claude Code (.jsonl) and Cursor (.db) local files",
    "Client-side parsing — no files uploaded",
    "Time saved estimates",
    "Category and task breakdowns",
    "Monthly wraps stored locally",
  ],
  creator: {
    "@type": "Organization",
    name: "AI Wrapped",
  },
};
---

<BaseLayout isLanding title={`${brand.name} — Your Month in AI`} description={brand.description}>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} slot="head" />
  <div id="landing-static" class="pb-8">
    <div id="landing-marketing">
    <section class="max-w-4xl mx-auto text-center min-h-[85vh] flex flex-col justify-center items-center py-20">
      <h1 class="text-5xl sm:text-6xl md:text-8xl lg:text-9xl font-black tracking-tighter leading-none">
        {brand.heroHeadline}
      </h1>

      <div class="mt-10 sm:mt-12 mb-12 sm:mb-16">
        <div class="text-wrap-500 text-6xl sm:text-7xl md:text-8xl lg:text-9xl font-black text-glow">
          {samplePreview.hoursSaved}
        </div>
        <div class="text-xl sm:text-2xl md:text-3xl font-semibold mt-3 sm:mt-4 text-wrap-500/80">
          {samplePreview.savedLabel}
        </div>
        <p class="text-text-muted mt-4 text-base sm:text-lg px-4">
          {samplePreview.platformSummary}
        </p>
      </div>

      <p class="text-text-muted text-lg sm:text-xl max-w-2xl mx-auto leading-relaxed px-4">
        {brand.heroSubcopy}
      </p>

      <p class="mt-6 text-sm text-text-muted/60">{brand.heroTrustLine.join(" · ")}</p>
    </section>

    <div
      class="h-px w-full bg-gradient-to-r from-transparent via-white/5 to-transparent mb-20 sm:mb-32"
      aria-hidden="true"
    >
    </div>

    <section class="max-w-5xl mx-auto mb-20 sm:mb-32 pt-4">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 sm:gap-8">
        {
          samplePreview.breakdown.map((row) => (
            <article class="surface-card p-6 sm:p-8 rounded-3xl border border-white/5">
              <div class="flex justify-between items-end mb-4">
                <span class="text-xl font-bold">{row.label}</span>
                <span class="text-wrap-500 text-2xl font-black">{row.pct}%</span>
              </div>
              <div class="w-full bg-white/10 h-4 rounded-full overflow-hidden">
                <div class="bg-wrap-500 h-full rounded-full" style={`width: ${row.pct}%`} />
              </div>
              <p class="mt-4 text-text-muted text-sm italic">Top task: {row.topTask}</p>
            </article>
          ))
        }
      </div>
    </section>
    </div>

    <section id="upload-flow" class="max-w-3xl mx-auto pb-16 sm:pb-32" aria-label="Upload your exports">
      <div class="flex flex-col md:flex-row items-start md:items-center justify-between mb-8 gap-6">
        <div>
          <h2 class="text-2xl font-bold">Get your wrap</h2>
          <p class="text-text-muted mt-1">Pick the month, then drop your export files.</p>
        </div>
      </div>
      <HomeUpload client:load />
    </section>

    <div id="landing-more">
    <SponsorSlot client:load />

    <section class="max-w-3xl mx-auto mt-12 sm:mt-20 pt-12 sm:pt-20 border-t border-white/5">
      <ul class="space-y-6 text-text-muted mb-12">
        {
          brand.howItWorks.map((line) => (
            <li class="flex items-start gap-4">
              <span class="w-2 h-2 rounded-full bg-wrap-500 mt-2 shrink-0" aria-hidden="true" />
              <span>{line}</span>
            </li>
          ))
        }
      </ul>

      <div class="bg-wrap-500/5 border-l-4 border-wrap-500 p-6 rounded-r-xl mb-12">
        <p class="text-text-muted">
          {brand.privacyLine}{" "}
          <a href="/methodology" class="text-wrap-500 hover:underline">See the methodology</a>.
        </p>
      </div>

      <p class="text-[10px] text-text-muted/40 uppercase tracking-widest text-center">
        {brand.platformsLine}
      </p>
    </section>

    <PlatformGuide />

    <SupportProject />
    </div>
  </div>
</BaseLayout>
