---
import "@/styles/global.css";
import { brand } from "@/config/brand";

interface Props {
  title?: string;
  description?: string;
  isLanding?: boolean;
}

const {
  title = `${brand.name} — Your Month in AI`,
  description = brand.description,
  isLanding = false,
} = Astro.props;

const pathname = Astro.url.pathname;
const ogImageUrl = new URL(brand.ogImage, Astro.site ?? brand.url).href;
const secondaryNav = [
  { href: "/history", label: "History" },
  { href: "/methodology", label: "Methodology" },
  { href: "/settings", label: "Settings" },
];
---

<!doctype html>
<html lang="en">
  <head>
    <!-- Google Tag Manager -->
    <script is:inline>
      (function (w, d, s, l, i) {
        w[l] = w[l] || [];
        w[l].push({ "gtm.start": new Date().getTime(), event: "gtm.js" });
        var f = d.getElementsByTagName(s)[0],
          j = d.createElement(s),
          dl = l != "dataLayer" ? "&l=" + l : "";
        j.async = true;
        j.src = "https://www.googletagmanager.com/gtm.js?id=" + i + dl;
        f.parentNode.insertBefore(j, f);
      })(window, document, "script", "dataLayer", "GTM-TVQK99JQ");
    </script>
    <!-- End Google Tag Manager -->
    <meta charset="UTF-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800;900&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,0,0"
      rel="stylesheet"
    />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={new URL(pathname, Astro.site ?? brand.url).href} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1024" />
    <meta property="og:image:height" content="537" />
    <meta property="og:image:alt" content={brand.ogImageAlt} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content={brand.ogImageAlt} />
    <meta name="robots" content="index, follow" />
    <title>{title}</title>
    <slot name="head" />
  </head>
  <body class="font-sans antialiased">
    <!-- Google Tag Manager (noscript) -->
    <noscript>
      <iframe
        src="https://www.googletagmanager.com/ns.html?id=GTM-TVQK99JQ"
        height="0"
        width="0"
        style="display:none;visibility:hidden"
        title="Google Tag Manager"></iframe>
    </noscript>
    <!-- End Google Tag Manager (noscript) -->
    <noscript>
      <div class="max-w-3xl mx-auto px-6 py-24 text-center text-text-muted">
        <p>
          AI Wrapped needs JavaScript for file upload and report generation. The marketing content on
          this page is still visible above, but uploading exports requires a modern browser with
          JavaScript enabled.
        </p>
      </div>
    </noscript>
    <header class="fixed top-0 w-full z-50 bg-surface-900/80 backdrop-blur-md border-b border-white/5">
      <div class="max-w-7xl mx-auto px-6 h-20 flex items-center justify-between gap-4">
        <a href="/" class="font-bold text-xl tracking-tight">
          <span class="text-white">{brand.wordmark.primary}</span>
          {" "}
          <span class="text-wrap-500">{brand.wordmark.accent}</span>
        </a>
        <nav class="flex items-center gap-4 sm:gap-8">
          <div class="hidden md:flex items-center gap-8 text-sm font-medium text-text-muted">
            {
              secondaryNav.map(({ href, label }) => (
                <a
                  href={href}
                  class:list={[
                    "transition-colors hover:text-white",
                    pathname === href && "text-white",
                  ]}
                >
                  {label}
                </a>
              ))
            }
          </div>
          <a
            href="/"
            class:list={[
              "shrink-0 px-4 sm:px-5 py-2 rounded-full font-bold text-sm transition-all transform hover:scale-105",
              isLanding
                ? "bg-wrap-500 text-black hover:bg-white"
                : "bg-white/10 text-white hover:bg-wrap-500 hover:text-black",
            ]}
          >
            {brand.navUpload}
          </a>
        </nav>
      </div>
    </header>

    <main
      class:list={[
        "flex-1 w-full mx-auto px-6 pt-20",
        isLanding ? "max-w-7xl pb-20" : "max-w-5xl py-8",
      ]}
    >
      <slot />
    </main>

    <footer class="py-12 border-t border-white/5 text-center text-sm text-text-muted/40">
      <p>
        © {new Date().getFullYear()}
        {brand.name}. {brand.footerPrivacy}
      </p>
    </footer>
  </body>
</html>
